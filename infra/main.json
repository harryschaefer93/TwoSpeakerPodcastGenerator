                      "image": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1Gi"
                      },
                      "env": [
                        {
                          "name": "PORT",
                          "value": "3000"
                        },
                        {
                          "name": "NODE_ENV",
                          "value": "production"
                        },
                        {
                          "name": "SPEECH_ENDPOINT",
                          "value": "[parameters('speechEndpoint')]"
                        },
                        {
                          "name": "OUTPUT_CONTAINER_URL",
                          "value": "[parameters('outputContainerUrl')]"
                        },
                        {
                          "name": "AI_ENDPOINT",
                          "value": "[parameters('aiEndpoint')]"
                        },
                        {
                          "name": "AI_DEPLOYMENT",
                          "value": "[parameters('aiDeployment')]"
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 0,
                    "maxReplicas": 3,
                    "rules": [
                      {
                        "name": "http-scaling",
                        "http": {
                          "metadata": {
                            "concurrentRequests": "50"
                          }
                        }
                      }
                    ]
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]",
                "[resourceId('Microsoft.App/managedEnvironments', format('{0}-cae', parameters('baseName')))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]",
              "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), variables('acrPullRoleId'))]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), '2024-03-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('acrPullRoleId'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]",
                "[resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName')))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('aiFoundryName'))]",
              "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', parameters('aiFoundryName')), resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), variables('cognitiveServicesUserRoleId'))]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), '2024-03-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('cognitiveServicesUserRoleId'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName')))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
              "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), variables('storageBlobContributorRoleId'))]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), '2024-03-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageBlobContributorRoleId'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName')))]"
              ]
            }
          ],
          "outputs": {
            "containerAppFqdn": {
              "type": "string",
              "metadata": {
                "description": "FQDN of the deployed Container App."
              },
              "value": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), '2024-03-01').configuration.ingress.fqdn]"
            },
            "containerAppUrl": {
              "type": "string",
              "metadata": {
                "description": "Full URL of the deployed Container App."
              },
              "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), '2024-03-01').configuration.ingress.fqdn)]"
            },
            "acrLoginServer": {
              "type": "string",
              "metadata": {
                "description": "ACR login server for pushing images."
              },
              "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').loginServer]"
            },
            "containerAppName": {
              "type": "string",
              "metadata": {
                "description": "Container App resource name (used by azd deploy)."
              },
              "value": "[format('{0}-app', parameters('baseName'))]"
            },
            "appPrincipalId": {
              "type": "string",
              "metadata": {
                "description": "Container App managed identity principal ID."
              },
              "value": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-app', parameters('baseName'))), '2024-03-01', 'full').identity.principalId]"
            },
            "containerAppsEnvironmentName": {
              "type": "string",
              "metadata": {
                "description": "Container Apps Environment name."
              },
              "value": "[format('{0}-cae', parameters('baseName'))]"
            }
          }
        }
      },
      "dependsOn": [
        "aiStack",
        "rg"
      ]
    }
  },
  "outputs": {
    "containerAppUrl": {
      "type": "string",
      "metadata": {
        "description": "Container App URL."
      },
      "value": "[reference('hosting').outputs.containerAppUrl.value]"
    },
    "acrLoginServer": {
      "type": "string",
      "metadata": {
        "description": "ACR login server."
      },
      "value": "[reference('hosting').outputs.acrLoginServer.value]"
    },
    "AZURE_CONTAINER_REGISTRY_ENDPOINT": {
      "type": "string",
      "value": "[reference('hosting').outputs.acrLoginServer.value]"
    },
    "AZURE_CONTAINER_APP_NAME": {
      "type": "string",
      "value": "[reference('hosting').outputs.containerAppName.value]"
    },
    "AZURE_CONTAINER_APPS_ENVIRONMENT_NAME": {
      "type": "string",
      "value": "[reference('hosting').outputs.containerAppsEnvironmentName.value]"
    },
    "aiFoundryEndpoint": {
      "type": "string",
      "metadata": {
        "description": "AI Foundry endpoint URL (maps to AI_ENDPOINT)."
      },
      "value": "[reference('aiStack').outputs.aiFoundryEndpoint.value]"
    },
    "speechRegion": {
      "type": "string",
      "metadata": {
        "description": "Region name (maps to SPEECH_REGION)."
      },
      "value": "[reference('aiStack').outputs.speechRegion.value]"
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage account name."
      },
      "value": "[reference('aiStack').outputs.storageAccountNameOutput.value]"
    },
    "outputContainerUrl": {
      "type": "string",
      "metadata": {
        "description": "Blob container URL — use as OUTPUT_CONTAINER_SAS_URL when RBAC auth is active (no SAS query string needed)."
      },
      "value": "[reference('aiStack').outputs.outputContainerUrl.value]"
    },
    "aiFoundryPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "AI Foundry system-assigned identity principal ID (for additional external role grants)."
      },
      "value": "[reference('aiStack').outputs.aiFoundryPrincipalId.value]"
    },
    "aiDeploymentName": {
      "type": "string",
      "metadata": {
        "description": "Model deployment name (maps to AI_DEPLOYMENT)."
      },
      "value": "[reference('aiStack').outputs.aiDeploymentName.value]"
    }
  }
}