PORT=3000

# Azure AI Speech
SPEECH_KEY=
SPEECH_REGION=eastus
SPEECH_API_VERSION=2024-04-01
OUTPUT_AUDIO_FORMAT=audio-24khz-48kbitrate-mono-mp3
OUTPUT_CONTAINER_SAS_URL=
OUTPUT_CONTAINER_PUBLIC_BASE_URL=

# Resilience
RETRY_MAX_ATTEMPTS=6
RETRY_BASE_DELAY_MS=500
RETRY_MAX_DELAY_MS=10000

# Optional comma-separated host allowlist for intro/outro media URLs
MEDIA_ALLOWED_HOSTS=

# API security
# AUTH_MODE: none | api-key | jwt | api-key-or-jwt
AUTH_MODE=none
API_KEYS=
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=

# Optional comma-separated CORS allowlist (scheme + host + optional port)
# Example: https://podcastgen.contoso.com,https://admin.contoso.com
CORS_ALLOWED_ORIGINS=

# Voice config
USE_MULTITALKER=true
MULTITALKER_VOICE=en-US-MultiTalker-Ava-Andrew:DragonHDLatestNeural
SPEAKER_A_ALIAS=ava
SPEAKER_B_ALIAS=andrew
SPEAKER_A_FALLBACK_VOICE=en-US-Ava:DragonHDOmniLatestNeural
SPEAKER_B_FALLBACK_VOICE=en-US-Andrew:DragonHDOmniLatestNeural

# Script generation (Azure AI Foundry / OpenAI-compatible)
AI_ENDPOINT=
AI_API_KEY=
AI_DEPLOYMENT=gpt-4.1
AI_API_VERSION=2024-10-21
